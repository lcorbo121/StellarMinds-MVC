<!DOCTYPE html>
<html lang="es">
<head>
    <script>
        if (localStorage.getItem('sm-theme') === 'light') document.documentElement.style.setProperty('--pre-theme', 'light');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StellarMinds</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StellarMinds.styles.css" asp-append-version="true" />
    <style id="theme-style"></style>
</head>
<body>
@{
    var userName = Context.Session.GetString("userName");
    var rol      = Context.Session.GetString("rol");
    var logueado = !string.IsNullOrEmpty(userName);
}
<header>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">&#9733; StellarMinds</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                @if (logueado)
                {
                    <ul class="navbar-nav flex-grow-1">
                        @if (rol == "Administrador")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Socios</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Socios" asp-action="Create">Registrar socio</a></li>
                                    <li><a class="dropdown-item" asp-controller="Socios" asp-action="ListaTodos">Ver usuarios</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Equipos</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Equipos" asp-action="Index" asp-route-tipo="telescopios">Telescopios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Equipos" asp-action="Index" asp-route-tipo="monturas">Monturas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Equipos" asp-action="Index" asp-route-tipo="camaras">Cámaras</a></li>
                                    <li><a class="dropdown-item" asp-controller="Equipos" asp-action="Index" asp-route-tipo="oculares">Oculares</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Préstamos</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="Create">Registrar préstamo</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="Devolucion">Registrar devolución</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="TodosPrestamos">Ver todos</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="SociosPorTelescopio">Socios por telescopio</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="Auditoria">Auditoría</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Observaciones</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Observaciones" asp-action="Create">Registrar observación</a></li>
                                    <li><a class="dropdown-item" asp-controller="Observaciones" asp-action="TodasObservaciones">Ver todas</a></li>
                                </ul>
                            </li>
                        }
                        @if (rol == "Coordinador")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Préstamos</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="Create">Registrar préstamo</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="Devolucion">Registrar devolución</a></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="TodosPrestamos">Ver todos</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Prestamos" asp-action="SociosPorTelescopio">Socios por telescopio</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Observaciones" asp-action="TodasObservaciones">Observaciones</a>
                            </li>
                        }
                        @if (rol == "Socio")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Observaciones" asp-action="Create">Registrar observación</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Observaciones" asp-action="MisObservaciones">Mis observaciones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Prestamos" asp-action="MisPrestamos">Mis préstamos</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Observaciones" asp-action="Ranking">Ranking objetos celestes</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        <li class="nav-item">
                            <button class="theme-toggle-nav" id="themeToggleNav" title="Cambiar tema" aria-label="Cambiar tema">
                                <span id="themeIconNav">&#9790;</span>
                            </button>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <span class="badge bg-secondary me-1">@rol</span>@userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li><a class="dropdown-item text-danger" asp-controller="Usuarios" asp-action="Logout">Cerrar sesión</a></li>
                            </ul>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>
<footer class="border-top footer text-muted">
    <div class="container">&copy; 2026 - StellarMinds</div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
    (function () {
        var body = document.body;
        var icon = document.getElementById('themeIconNav');
        var btn  = document.getElementById('themeToggleNav');
        var isLight = localStorage.getItem('sm-theme') === 'light';

        function applyTheme(light) {
            if (light) {
                body.classList.add('light-mode');
                if (icon) icon.innerHTML = '&#9728;';
            } else {
                body.classList.remove('light-mode');
                if (icon) icon.innerHTML = '&#9790;';
            }
        }

        applyTheme(isLight);

        if (btn) {
            btn.addEventListener('click', function () {
                isLight = !isLight;
                localStorage.setItem('sm-theme', isLight ? 'light' : 'dark');
                applyTheme(isLight);
            });
        }
    })();
</script>
<script>
    (function () {
        var SOMEE_KEYWORDS = ['somee', 'virtual server', 'hosted windows', '2.5ghz', 'ads.mgmt'];

        function containsSomee(el) {
            var text = (el.textContent || '').toLowerCase();
            var html = (el.innerHTML || '').toLowerCase();
            return SOMEE_KEYWORDS.some(function(k) { return text.includes(k) || html.includes(k); });
        }

        function removeEl(el) {
            el.style.cssText += ';display:none!important;visibility:hidden!important;height:0!important;overflow:hidden!important;';
            try { el.remove(); } catch (e) { }
        }

        function removeSomeeWatermarks() {
            // 1. Bloquear scripts de somee antes de que carguen
            document.querySelectorAll('script[src*="somee.com"]').forEach(removeEl);

            // 2. Subir al hijo directo de body para cualquier link/img/iframe a somee
            document.querySelectorAll('a[href*="somee.com"], img[src*="somee.com"], iframe[src*="somee.com"]').forEach(function (el) {
                var target = el;
                var p = el.parentElement;
                while (p && p !== document.body && p !== document.documentElement) {
                    target = p;
                    p = p.parentElement;
                }
                removeEl(target);
            });

            // 3. Apuntar por z-index máximo (firma única del banner de SOMEE)
            document.querySelectorAll('[style*="2147483647"]').forEach(removeEl);

            // 4. Escanear hijos directos de body por texto de SOMEE (captura el banner de WholeInsert5.js)
            Array.from(document.body.children).forEach(function (el) {
                var tag = el.tagName;
                if (tag === 'HEADER' || tag === 'MAIN' || tag === 'FOOTER' || tag === 'DIV' && el.classList.contains('container')) return;
                if (el.style && el.style.zIndex === '2147483647') { removeEl(el); return; }
                if (containsSomee(el)) removeEl(el);
            });
        }

        removeSomeeWatermarks();

        new MutationObserver(function () {
            setTimeout(removeSomeeWatermarks, 0);
        }).observe(document.documentElement, { childList: true, subtree: true });

        window.addEventListener('load', function () {
            [0, 300, 800, 1500, 3000].forEach(function(ms) {
                setTimeout(removeSomeeWatermarks, ms);
            });
        });
    })();
</script>
</body>
</html>
