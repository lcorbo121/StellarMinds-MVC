@model StellarMinds.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StellarMinds - Iniciar sesión</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        /* --- Dark mode (default) --- */
        body {
            background-color: #0d1117;
            transition: background-color .3s, color .3s;
        }
        .login-card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; }
        .login-title { color: #c9d1d9; }
        .login-subtitle { color: #8b949e; }
        .form-control { background-color: #0d1117; border-color: #30363d; color: #c9d1d9; }
        .form-control:focus { background-color: #0d1117; border-color: #388bfd; color: #c9d1d9; box-shadow: 0 0 0 0.2rem rgba(56,139,253,.25); }
        .form-control::placeholder { color: #484f58; }
        .form-label { color: #8b949e; }
        .btn-login { background-color: #238636; border-color: #2ea043; color: #fff; width: 100%; }
        .btn-login:hover { background-color: #2ea043; border-color: #3fb950; color: #fff; }
        .btn-eye { background-color: #0d1117; border: 1px solid #30363d; color: #8b949e; display: flex; align-items: center; }
        .btn-eye:hover { background-color: #0d1117; color: #c9d1d9; }
        body.light-mode .btn-eye { background-color: #f6f8fa; border-color: #d0d7de; color: #57606a; }
        body.light-mode .btn-eye:hover { background-color: #f6f8fa; color: #24292f; }
        .star-icon { color: #f0c040; font-size: 2.5rem; }
        .copyright { color: #484f58; font-size: .85rem; }

        /* --- Light mode --- */
        body.light-mode { background-color: #f6f8fa; }
        body.light-mode .login-card { background: #ffffff; border-color: #d0d7de; }
        body.light-mode .login-title { color: #24292f; }
        body.light-mode .login-subtitle { color: #57606a; }
        body.light-mode .form-control { background-color: #f6f8fa; border-color: #d0d7de; color: #24292f; }
        body.light-mode .form-control:focus { background-color: #ffffff; border-color: #0969da; color: #24292f; box-shadow: 0 0 0 0.2rem rgba(9,105,218,.25); }
        body.light-mode .form-control::placeholder { color: #8c959f; }
        body.light-mode .form-label { color: #57606a; }
        body.light-mode .copyright { color: #8c959f; }

        /* --- Theme toggle button --- */
        .theme-toggle {
            position: fixed;
            top: 1rem;
            left: 1rem;
            z-index: 1000;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 50%;
            border: 1px solid #30363d;
            background: #161b22;
            color: #c9d1d9;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            transition: background .3s, border-color .3s, color .3s;
        }
        .theme-toggle:hover { border-color: #8b949e; }
        body.light-mode .theme-toggle { background: #ffffff; border-color: #d0d7de; color: #24292f; }
        body.light-mode .theme-toggle:hover { border-color: #0969da; }
    </style>
    <script>
        (function () {
            if (localStorage.getItem('sm-theme') === 'light') {
                document.documentElement.classList.add('light-mode-pending');
            }
        })();
    </script>
</head>
<body class="d-flex align-items-center min-vh-100">

    <button class="theme-toggle" id="themeToggle" title="Cambiar tema" aria-label="Cambiar tema">
        <span id="themeIcon">&#9790;</span>
    </button>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="text-center mb-4">
                    <div class="star-icon mb-2">&#9733;</div>
                    <h1 class="h3 login-title fw-bold">StellarMinds</h1>
                    <p class="login-subtitle">Observatorio & Club de Astronomía</p>
                </div>
                <div class="login-card p-4">
                    <h2 class="h5 login-title mb-4">Iniciar sesión</h2>
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2" role="alert">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }
                    <form asp-action="Index" asp-controller="Usuarios" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control" placeholder="Ingrese su usuario" autocomplete="username" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" placeholder="Ingrese su contraseña" autocomplete="current-password" />
                                <button class="btn btn-eye" type="button" id="togglePassword" tabindex="-1" aria-label="Mostrar contraseña" title="Mostrar u ocultar contraseña">
                                    <svg id="iconEye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>
                                    <svg id="iconEyeSlash" class="d-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829"/><path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709z"/><path d="m13.646 14.354-12-12 .708-.708 12 12z"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-login">Ingresar</button>
                    </form>
                </div>
                <p class="text-center mt-3 copyright">&copy; 2026 StellarMinds</p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            var SOMEE_KEYWORDS = ['somee', 'virtual server', 'hosted windows', '2.5ghz', 'ads.mgmt'];
            function containsSomee(el) {
                var text = (el.textContent || '').toLowerCase();
                var html = (el.innerHTML || '').toLowerCase();
                return SOMEE_KEYWORDS.some(function (k) { return text.includes(k) || html.includes(k); });
            }
            function removeEl(el) {
                el.style.cssText += ';display:none!important;visibility:hidden!important;height:0!important;overflow:hidden!important;';
                try { el.remove(); } catch (e) { }
            }
            function removeSomeeWatermarks() {
                document.querySelectorAll('script[src*="somee.com"]').forEach(removeEl);
                document.querySelectorAll('a[href*="somee.com"], img[src*="somee.com"], iframe[src*="somee.com"]').forEach(function (el) {
                    var target = el, p = el.parentElement;
                    while (p && p !== document.body && p !== document.documentElement) { target = p; p = p.parentElement; }
                    removeEl(target);
                });
                document.querySelectorAll('[style*="2147483647"]').forEach(removeEl);
                Array.from(document.body.children).forEach(function (el) {
                    if (el.tagName === 'SCRIPT' || el.id === 'main-container') return;
                    if (el.style && el.style.zIndex === '2147483647') { removeEl(el); return; }
                    if (containsSomee(el)) removeEl(el);
                });
            }
            removeSomeeWatermarks();
            new MutationObserver(function () { setTimeout(removeSomeeWatermarks, 0); })
                .observe(document.documentElement, { childList: true, subtree: true });
            window.addEventListener('load', function () {
                [0, 300, 800, 1500, 3000].forEach(function (ms) { setTimeout(removeSomeeWatermarks, ms); });
            });
        })();
    </script>
    <script>
        (function () {
            var body = document.body;
            var icon = document.getElementById('themeIcon');
            var isLight = localStorage.getItem('sm-theme') === 'light';

            function applyTheme(light) {
                if (light) {
                    body.classList.add('light-mode');
                    icon.innerHTML = '&#9728;';
                } else {
                    body.classList.remove('light-mode');
                    icon.innerHTML = '&#9790;';
                }
            }

            applyTheme(isLight);

            document.getElementById('themeToggle').addEventListener('click', function () {
                isLight = !isLight;
                localStorage.setItem('sm-theme', isLight ? 'light' : 'dark');
                applyTheme(isLight);
            });
        })();
    </script>
    <script>
        (function () {
            var input = document.getElementById('Password');
            var btn = document.getElementById('togglePassword');
            if (!input || !btn) return;
            var eye = document.getElementById('iconEye');
            var eyeSlash = document.getElementById('iconEyeSlash');
            btn.addEventListener('click', function () {
                var mostrar = input.type === 'password';
                input.type = mostrar ? 'text' : 'password';
                eye.classList.toggle('d-none', mostrar);
                eyeSlash.classList.toggle('d-none', !mostrar);
                btn.setAttribute('aria-label', mostrar ? 'Ocultar contraseña' : 'Mostrar contraseña');
            });
        })();
    </script>
</body>
</html>
