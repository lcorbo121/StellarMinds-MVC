@model List<StellarMinds.Models.Usuarios.UsuarioListaItem>
@{
    ViewData["Title"] = "Usuarios del sistema";

    string RolBadgeClass(string? rol) => rol switch {
        "Administrador" => "bg-danger",
        "Coordinador"   => "bg-warning text-dark",
        _               => "bg-primary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuarios del sistema</h2>
    <div class="d-flex gap-2">
        <span class="badge bg-danger fs-6">@Model.Count(u => u.Rol == "Administrador") Admin</span>
        <span class="badge bg-warning text-dark fs-6">@Model.Count(u => u.Rol == "Coordinador") Coord.</span>
        <span class="badge bg-primary fs-6">@Model.Count(u => u.Rol == "Socio") Socios</span>
    </div>
</div>

<div class="mb-3">
    <input type="text" id="filtroTexto" class="form-control" placeholder="Buscar por nombre, usuario o email..." />
</div>

<div class="mb-3 d-flex gap-2 flex-wrap" id="filtroRol">
    <button class="btn btn-sm btn-secondary active" data-rol="">Todos</button>
    <button class="btn btn-sm btn-danger"  data-rol="Administrador">Administrador</button>
    <button class="btn btn-sm btn-warning text-dark" data-rol="Coordinador">Coordinador</button>
    <button class="btn btn-sm btn-primary" data-rol="Socio">Socio</button>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay usuarios registrados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle" id="tablaUsuarios">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Rol</th>
                    <th>Nombre completo</th>
                    <th>Usuario</th>
                    <th>Email</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr data-rol="@u.Rol" data-texto="@($"{u.NombreCompleto} {u.UserName} {u.Email}".ToLower())">
                        <td class="text-muted small">@u.Id</td>
                        <td><span class="badge @RolBadgeClass(u.Rol)">@u.Rol</span></td>
                        <td>@u.NombreCompleto</td>
                        <td><code>@u.UserName</code></td>
                        <td class="text-muted small">@u.Email</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
(function () {
    var rolActivo = '';

    document.getElementById('filtroTexto').addEventListener('input', filtrar);

    document.querySelectorAll('#filtroRol button').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('#filtroRol button').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            rolActivo = btn.dataset.rol;
            filtrar();
        });
    });

    function filtrar() {
        var texto = document.getElementById('filtroTexto').value.toLowerCase();
        document.querySelectorAll('#tablaUsuarios tbody tr').forEach(function (tr) {
            var matchRol   = !rolActivo || tr.dataset.rol === rolActivo;
            var matchTexto = !texto    || tr.dataset.texto.includes(texto);
            tr.style.display = (matchRol && matchTexto) ? '' : 'none';
        });
    }
})();
</script>
}
