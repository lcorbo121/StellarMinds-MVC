@model StellarMinds.Models.Usuarios.UsuarioListaItem
@{
    ViewData["Title"] = "Detalle del socio";
}

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Socio <span class="text-muted fs-4">#@Model.Id</span></h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-outline-primary">+ Registrar otro</a>
        <a asp-action="ListaTodos" class="btn btn-outline-secondary">← Ver todos</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header fw-semibold">Información del socio</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Nombre completo</div><div class="fw-semibold">@Model.NombreCompleto</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Usuario</div><div>@Model.UserName</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Email</div><div>@Model.Email</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Rol</div><div><span class="badge bg-secondary">@Model.Rol</span></div></div>
        </div>
    </div>
</div>
