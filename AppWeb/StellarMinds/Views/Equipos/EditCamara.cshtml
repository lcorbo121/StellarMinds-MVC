@model StellarMinds.Models.Equipos.CamaraViewModel
@{ ViewData["Title"] = "Editar cámara"; var tipo = (string)(ViewBag.Tipo ?? "camaras"); }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Editar cámara</h2><a asp-action="Index" asp-route-tipo="@tipo" class="btn btn-outline-secondary">Volver</a></div>
<div class="row"><div class="col-md-7"><div class="card shadow-sm"><div class="card-body">
<form asp-action="EditCamara" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="tipo" value="@tipo" />
    <input type="hidden" asp-for="Id" />
    <div class="row mb-3">
        <div class="col-md-6"><label asp-for="Marca" class="form-label"></label><input asp-for="Marca" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Modelo" class="form-label"></label><input asp-for="Modelo" class="form-control" /></div>
    </div>
    <div class="mb-3">
        <label asp-for="TipoSensor" class="form-label"></label>
        <select asp-for="TipoSensor" class="form-select"><option value="CMOS">CMOS</option><option value="CCD">CCD</option></select>
    </div>
    <div class="mb-3"><label asp-for="Resolucion" class="form-label"></label><input asp-for="Resolucion" class="form-control" /></div>
    <div class="row mb-3">
        <div class="col-md-6"><label asp-for="TamanoPixel" class="form-label"></label><input asp-for="TamanoPixel" class="form-control" type="number" step="0.01" min="0.01" /></div>
        <div class="col-md-6"><label asp-for="CantidadDisponible" class="form-label"></label><input asp-for="CantidadDisponible" class="form-control" type="number" min="0" /></div>
    </div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Guardar cambios</button><a asp-action="Index" asp-route-tipo="@tipo" class="btn btn-outline-secondary">Cancelar</a></div>
</form>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
