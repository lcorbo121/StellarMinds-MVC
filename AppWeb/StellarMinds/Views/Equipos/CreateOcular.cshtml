@model StellarMinds.Models.Equipos.OcularViewModel
@{ ViewData["Title"] = "Agregar ocular"; var tipo = (string)(ViewBag.Tipo ?? "oculares"); }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Agregar ocular</h2><a asp-action="Index" asp-route-tipo="@tipo" class="btn btn-outline-secondary">Volver</a></div>
<div class="row"><div class="col-md-7"><div class="card shadow-sm"><div class="card-body">
<form asp-action="CreateOcular" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="tipo" value="@tipo" />
    <div class="row mb-3">
        <div class="col-md-6"><label asp-for="Marca" class="form-label"></label><input asp-for="Marca" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Modelo" class="form-label"></label><input asp-for="Modelo" class="form-control" /></div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6"><label asp-for="Diametro" class="form-label"></label><input asp-for="Diametro" class="form-control" type="number" step="0.1" min="0.1" /></div>
        <div class="col-md-6"><label asp-for="AnguloVision" class="form-label"></label><input asp-for="AnguloVision" class="form-control" type="number" step="0.1" min="0.1" /></div>
    </div>
    <div class="mb-3"><label asp-for="CantidadDisponible" class="form-label"></label><input asp-for="CantidadDisponible" class="form-control" type="number" min="0" /></div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Guardar</button><a asp-action="Index" asp-route-tipo="@tipo" class="btn btn-outline-secondary">Cancelar</a></div>
</form>
</div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
