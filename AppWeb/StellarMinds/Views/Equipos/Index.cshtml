@{
    ViewData["Title"] = "Equipos";
    var tipo = (string)(ViewBag.Tipo ?? "telescopios");
    var equiposJson = (string)(ViewBag.Equipos ?? "[]");
    var rol = Context.Session.GetString("rol");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Gestión de equipos</h2>
    @if (rol == "Administrador")
    {
        <a asp-action="Create" asp-route-tipo="@tipo" class="btn btn-success">+ Agregar equipo</a>
    }
</div>

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="card shadow-sm mb-3"><div class="card-body py-2">
    <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
        <label class="form-label mb-0 fw-semibold">Tipo de equipo:</label>
        <select name="tipo" class="form-select w-auto" onchange="this.form.submit()">
            @if (tipo == "telescopios") { <option value="telescopios" selected>Telescopios</option> } else { <option value="telescopios">Telescopios</option> }
            @if (tipo == "monturas") { <option value="monturas" selected>Monturas</option> } else { <option value="monturas">Monturas</option> }
            @if (tipo == "camaras") { <option value="camaras" selected>Cámaras</option> } else { <option value="camaras">Cámaras</option> }
            @if (tipo == "oculares") { <option value="oculares" selected>Oculares</option> } else { <option value="oculares">Oculares</option> }
        </select>
    </form>
</div></div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle" id="tablaEquipos">
        <thead class="table-dark" id="encabezado"></thead>
        <tbody id="cuerpoTabla"><tr><td colspan="10" class="text-center text-muted">Cargando...</td></tr></tbody>
    </table>
</div>

@section Scripts {
<script>
    const tipo = '@Html.Raw(tipo)';
    const equipos = @Html.Raw(equiposJson);
    const esAdmin = '@rol' === 'Administrador';

    const columnas = {
        telescopios: [{key:'id',label:'ID'},{key:'marca',label:'Marca'},{key:'modelo',label:'Modelo'},{key:'apertura',label:'Apertura (mm)'},{key:'relacionFocal',label:'Rel. focal'},{key:'distanciaFocal',label:'Dist. focal (mm)'},{key:'peso',label:'Peso (kg)'},{key:'cantidadDisponible',label:'Disponibles'}],
        monturas: [{key:'id',label:'ID'},{key:'marca',label:'Marca'},{key:'modelo',label:'Modelo'},{key:'tipoMontura',label:'Tipo',format:v=>v===1?'Ecuatorial':v===2?'Alt-Azimutal':'Híbrida'},{key:'cargaUtil',label:'Carga útil (kg)'},{key:'esGoTo',label:'GoTo',format:v=>v?'<span class="badge bg-success">Sí</span>':'<span class="badge bg-secondary">No</span>'},{key:'cantidadDisponible',label:'Disponibles'}],
        camaras: [{key:'id',label:'ID'},{key:'marca',label:'Marca'},{key:'modelo',label:'Modelo'},{key:'tipoSensor',label:'Sensor',format:v=>v===1?'CCD':'CMOS'},{key:'resolucion',label:'Resolución'},{key:'tamanoPixel',label:'Píxel (µm)'},{key:'cantidadDisponible',label:'Disponibles'}],
        oculares: [{key:'id',label:'ID'},{key:'marca',label:'Marca'},{key:'modelo',label:'Modelo'},{key:'diametro',label:'Diámetro (mm)'},{key:'anguloVision',label:'Campo visual (°)'},{key:'cantidadDisponible',label:'Disponibles'}]
    };

    const cols = columnas[tipo] || columnas.telescopios;
    const thead = document.getElementById('encabezado');
    const headerRow = document.createElement('tr');
    cols.forEach(c => { const th = document.createElement('th'); th.textContent = c.label; headerRow.appendChild(th); });
    if (esAdmin) { const th = document.createElement('th'); th.textContent = 'Acciones'; headerRow.appendChild(th); }
    thead.appendChild(headerRow);

    const tbody = document.getElementById('cuerpoTabla');
    tbody.innerHTML = '';
    if (!equipos || equipos.length === 0) {
        tbody.innerHTML = '<tr><td colspan="' + (cols.length + (esAdmin?1:0)) + '" class="text-center text-muted">No hay equipos registrados.</td></tr>';
    } else {
        equipos.forEach(eq => {
            const tr = document.createElement('tr');
            cols.forEach(c => { const td = document.createElement('td'); const val = eq[c.key]; td.innerHTML = c.format ? c.format(val) : (val != null ? val : '—'); tr.appendChild(td); });
            if (esAdmin) {
                const tdAcc = document.createElement('td');
                tdAcc.innerHTML = `<a href="/Equipos/Edit?tipo=${tipo}&id=${eq.id}" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                    <form method="post" action="/Equipos/Delete" class="d-inline" onsubmit="return confirm('¿Eliminar este equipo?')">
                        <input type="hidden" name="tipo" value="${tipo}" /><input type="hidden" name="id" value="${eq.id}" />
                        <input type="hidden" name="__RequestVerificationToken" value="" class="aft-token" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>`;
                tr.appendChild(tdAcc);
            }
            tbody.appendChild(tr);
        });
        const token = document.querySelector('input[name=__RequestVerificationToken]');
        if (token) document.querySelectorAll('.aft-token').forEach(el => el.value = token.value);
    }
</script>
<form id="af" style="display:none">@Html.AntiForgeryToken()</form>
<script>
    const aft = document.querySelector('#af input[name=__RequestVerificationToken]');
    if (aft) document.querySelectorAll('.aft-token').forEach(el => el.value = aft.value);
</script>
}
