@model StellarMinds.Models.Equipos.EquipoDetalleItem
@{
    ViewData["Title"] = "Detalle del equipo";
    var tipo = (ViewBag.Tipo as string ?? "").ToLower();

    var (titulo, icono) =
        tipo.StartsWith("montura") ? ("Montura", "📐") :
        tipo.StartsWith("camara")  ? ("Cámara", "📷") :
        tipo.StartsWith("ocular")  ? ("Ocular", "🔬") :
                                     ("Telescopio", "🔭");
}

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@icono @titulo <span class="text-muted fs-4">#@Model.Id</span></h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" asp-route-tipo="@tipo" class="btn btn-outline-primary">+ Crear otro</a>
        <a asp-action="Index" asp-route-tipo="@tipo" class="btn btn-outline-secondary">← Ver lista</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header fw-semibold">Información del equipo</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Marca</div><div class="fw-semibold">@Model.Marca</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Modelo</div><div>@Model.Modelo</div></div>

            @if (titulo == "Telescopio")
            {
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Apertura (mm)</div><div>@Model.Apertura</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Relación focal</div><div>f/@Model.RelacionFocal</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Distancia focal (mm)</div><div>@Model.DistanciaFocal</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Peso (kg)</div><div>@Model.Peso</div></div>
            }
            else if (titulo == "Montura")
            {
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Tipo</div><div>@Model.TipoMontura</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Carga útil (kg)</div><div>@Model.CargaUtil</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">GoTo</div><div>@(Model.EsGoTo == true ? "Sí" : "No")</div></div>
            }
            else if (titulo == "Cámara")
            {
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Sensor</div><div>@Model.TipoSensor</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Resolución</div><div>@Model.Resolucion</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Tamaño píxel (μm)</div><div>@Model.TamanoPixel</div></div>
            }
            else
            {
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Diámetro (mm)</div><div>@Model.Diametro</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Campo aparente (°)</div><div>@Model.AnguloVision</div></div>
            }

            <div class="col-sm-6 col-md-4"><div class="text-muted small">Disponibles</div><div class="fw-semibold">@Model.CantidadDisponible</div></div>
        </div>
    </div>
</div>
