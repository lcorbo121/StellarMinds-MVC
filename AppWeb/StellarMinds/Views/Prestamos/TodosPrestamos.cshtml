@model List<StellarMinds.Models.Prestamos.PrestamoListaItem>
@{
    ViewData["Title"] = "Todos los préstamos";
    var enPrestamo = Model.Count(p => p.Estado == "EN PRÉSTAMO");
    var devueltos  = Model.Count(p => p.Estado == "DEVUELTO");
    var atrasados  = Model.Count(p => p.Atrasado);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Todos los préstamos</h2>
    <div class="d-flex gap-2">
        <span class="badge bg-primary fs-6">@Model.Count total</span>
        <span class="badge bg-warning text-dark fs-6">@enPrestamo en préstamo</span>
        <span class="badge bg-success fs-6">@devueltos devueltos</span>
        @if (atrasados > 0)
        {
            <span class="badge bg-danger fs-6">@atrasados atrasados</span>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay préstamos registrados.</div>
}
else
{
    <div class="row g-2 mb-3">
        <div class="col-md-6">
            <input type="text" id="filtro" class="form-control" placeholder="Filtrar por socio, telescopio..." />
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm filtro-estado active" data-estado="">Todos</button>
            <button class="btn btn-outline-warning btn-sm filtro-estado" data-estado="EN PRÉSTAMO">En préstamo</button>
            <button class="btn btn-outline-success btn-sm filtro-estado" data-estado="DEVUELTO">Devueltos</button>
            <button class="btn btn-outline-danger btn-sm filtro-estado" data-estado="ATRASADO">Atrasados</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle" id="tablaPrestamos">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Socio</th>
                    <th>Telescopio</th>
                    <th>Montura</th>
                    <th>Accesorio</th>
                    <th>Inicio</th>
                    <th>Vencimiento</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var estadoCss   = p.Estado == "DEVUELTO" ? "success" : p.Atrasado ? "danger" : "warning";
                    var estadoLabel = p.Atrasado ? "ATRASADO" : p.Estado;
                    <tr data-estado="@p.Estado" data-atrasado="@p.Atrasado.ToString().ToLower()">
                        <td class="text-muted small">@p.Id</td>
                        <td><strong>@p.UsuarioNombre</strong></td>
                        <td>@p.TelescopioNombre</td>
                        <td class="text-muted small">@p.MonturaNombre</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.CamaraNombre))
                            {
                                <span class="badge bg-info text-dark">Cám</span> <span class="small">@p.CamaraNombre</span>
                            }
                            else if (!string.IsNullOrEmpty(p.OcularNombre))
                            {
                                <span class="badge bg-secondary">Ocular</span> <span class="small">@p.OcularNombre</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="small">@p.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td class="small @(p.Atrasado ? "text-danger fw-bold" : "")">@p.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge bg-@estadoCss">@estadoLabel</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
    var filtroTexto = document.getElementById('filtro');
    var estadoActivo = '';

    function aplicarFiltros() {
        var q = filtroTexto ? filtroTexto.value.toLowerCase() : '';
        document.querySelectorAll('#tablaPrestamos tbody tr').forEach(function(tr) {
            var textoOk = !q || tr.textContent.toLowerCase().includes(q);
            var estadoOk = true;
            if (estadoActivo === 'ATRASADO') {
                estadoOk = tr.dataset.atrasado === 'true';
            } else if (estadoActivo !== '') {
                estadoOk = tr.dataset.estado === estadoActivo;
            }
            tr.style.display = (textoOk && estadoOk) ? '' : 'none';
        });
    }

    if (filtroTexto) filtroTexto.addEventListener('input', aplicarFiltros);

    document.querySelectorAll('.filtro-estado').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.filtro-estado').forEach(function(b) { b.classList.remove('active'); });
            this.classList.add('active');
            estadoActivo = this.dataset.estado;
            aplicarFiltros();
        });
    });
</script>
}
