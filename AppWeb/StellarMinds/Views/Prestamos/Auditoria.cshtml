@model StellarMinds.Models.Prestamos.AuditoriaViewModel
@{
    ViewData["Title"] = "Auditoría de préstamos";
}
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Auditoría de préstamos</h2></div>

<div class="card shadow-sm mb-4"><div class="card-body py-3">
    <form asp-action="Auditoria" method="get" class="row g-2 align-items-end">
        <div class="col-auto">
            <label for="coordinadorId" class="form-label mb-1">Filtrar por coordinador que dio el alta</label>
            <select name="coordinadorId" id="coordinadorId" class="form-select">
                <option value="">-- Todos --</option>
                @foreach (var c in Model.Coordinadores.Where(c => c.Rol == "Coordinador")) {
                    if (Model.CoordinadorSeleccionado == c.Id) { <option value="@c.Id" selected>@c.NombreCompleto</option> }
                    else { <option value="@c.Id">@c.NombreCompleto</option> }
                }
            </select>
        </div>
        <div class="col-auto"><button type="submit" class="btn btn-primary">Filtrar</button>
        @if (Model.CoordinadorSeleccionado.HasValue) { <a asp-action="Auditoria" class="btn btn-outline-secondary ms-1">Limpiar</a> }</div>
    </form>
</div></div>

<div class="table-responsive"><table class="table table-striped table-hover align-middle">
    <thead class="table-dark"><tr><th>#</th><th>Socio</th><th>Telescopio</th><th>Estado</th><th>Coordinador (alta)</th><th>Auditoría</th></tr></thead>
    <tbody>
    @if (!Model.Prestamos.Any()) { <tr><td colspan="6" class="text-center text-muted">No hay préstamos para mostrar.</td></tr> }
    else { @foreach (var item in Model.Prestamos) {
        var p = item.Prestamo;
        var estadoCss = p.Estado == "DEVUELTO" ? "success" : p.Atrasado ? "danger" : "warning";
        var estadoLabel = p.Atrasado ? "ATRASADO" : p.Estado;
        <tr>
            <td class="text-muted small">@p.Id</td>
            <td><strong>@p.UsuarioNombre</strong></td>
            <td>@p.TelescopioNombre</td>
            <td><span class="badge bg-@estadoCss">@estadoLabel</span></td>
            <td>@item.CoordinadorNombre</td>
            <td><a asp-action="AuditoriaPrestamo" asp-route-prestamoId="@p.Id" class="btn btn-sm btn-outline-info">Ver auditoría</a></td>
        </tr>
    } }
    </tbody>
</table></div>
