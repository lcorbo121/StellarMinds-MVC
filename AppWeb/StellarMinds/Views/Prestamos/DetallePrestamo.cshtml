@model StellarMinds.Models.Prestamos.PrestamoListaItem
@{
    ViewData["Title"] = "Detalle del préstamo";
    var esAdmin = Context.Session.GetString("rol") == "Administrador";

    string EstadoBadge(string? estado, bool atrasado)
    {
        if (atrasado) return "bg-danger";
        return estado switch { "DEVUELTO" => "bg-success", _ => "bg-warning text-dark" };
    }
    var etiqueta = Model.Atrasado ? "ATRASADO" : Model.Estado;
}

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Préstamo <span class="text-muted fs-4">#@Model.Id</span></h2>
    <div class="d-flex gap-2">
        <a asp-controller="Prestamos" asp-action="Create" class="btn btn-outline-primary">+ Registrar otro</a>
        @if (esAdmin)
        {
            <a asp-action="AuditoriaPrestamo" asp-route-prestamoId="@Model.Id" class="btn btn-outline-info">Ver auditoría</a>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Información del préstamo</span>
        <span class="badge fs-6 @EstadoBadge(Model.Estado, Model.Atrasado)">@etiqueta</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-md-4">
                <div class="text-muted small">Socio</div>
                <div class="fw-semibold">@Model.UsuarioNombre</div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="text-muted small">Fecha inicio</div>
                <div>@Model.FechaInicio.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="text-muted small">Fecha fin</div>
                <div class="@(Model.Atrasado ? "text-danger fw-semibold" : "")">@Model.FechaFin.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="text-muted small">Telescopio</div>
                <div>@Model.TelescopioNombre</div>
            </div>
            <div class="col-sm-6 col-md-4">
                <div class="text-muted small">Montura</div>
                <div>@Model.MonturaNombre</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.CamaraNombre))
            {
                <div class="col-sm-6 col-md-4">
                    <div class="text-muted small">Cámara</div>
                    <div>@Model.CamaraNombre</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.OcularNombre))
            {
                <div class="col-sm-6 col-md-4">
                    <div class="text-muted small">Ocular</div>
                    <div>@Model.OcularNombre</div>
                </div>
            }
        </div>
    </div>
</div>
