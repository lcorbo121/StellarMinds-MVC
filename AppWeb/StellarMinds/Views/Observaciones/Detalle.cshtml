@model StellarMinds.Models.Observaciones.ObservacionItem
@{
    ViewData["Title"] = "Detalle de la observación";
    var css = Model.IndicadorIA switch { "IDEAL" => "success", "ADECUADO" => "warning", "NO RECOMENDABLE" => "danger", _ => "secondary" };
}

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Observación <span class="text-muted fs-4">#@Model.Id</span></h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-outline-primary">+ Registrar otra</a>
        <a asp-action="MisObservaciones" class="btn btn-outline-secondary">← Mis observaciones</a>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Información de la observación</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Fecha</div><div class="fw-semibold">@Model.FechaObservacion</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Objeto celeste</div><div>@Model.ObjetoCeleste</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Tipo de objeto</div><div>@Model.TipoObjeto</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Telescopio</div><div>@Model.Telescopio</div></div>
            <div class="col-sm-6 col-md-4"><div class="text-muted small">Socio</div><div>@Model.Socio</div></div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Notas))
        {
            <div class="mt-3"><div class="text-muted small">Notas</div><div>@Model.Notas</div></div>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.IndicadorIA))
{
    <div class="alert alert-@css">
        <strong>Evaluación IA: @Model.IndicadorIA</strong>
        @if (!string.IsNullOrWhiteSpace(Model.DetalleIA)) { <p class="mb-0 mt-1">@Model.DetalleIA</p> }
    </div>
}
