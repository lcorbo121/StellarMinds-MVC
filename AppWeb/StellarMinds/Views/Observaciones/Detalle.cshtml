@{
    ViewData["Title"] = "Detalle de la observación";
    var o = ViewBag.Observacion as System.Text.Json.JsonElement?;
    string Str(System.Text.Json.JsonElement el, string key) =>
        el.TryGetProperty(key, out var v) ? (v.GetString() ?? "—") : "—";
}

@if (TempData["Exito"] != null) { <div class="alert alert-success alert-dismissible fade show">@TempData["Exito"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Observación @if (o.HasValue) { <span class="text-muted fs-4">#@(o.Value.TryGetProperty("id", out var idv) ? idv.GetInt32() : 0)</span> }</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-outline-primary">+ Registrar otra</a>
        <a asp-action="MisObservaciones" class="btn btn-outline-secondary">← Mis observaciones</a>
    </div>
</div>

@if (o.HasValue)
{
    var indicador = Str(o.Value, "indicadorIA");
    var css = indicador switch { "IDEAL" => "success", "ADECUADO" => "warning", "NO RECOMENDABLE" => "danger", _ => "secondary" };
    var detalle = Str(o.Value, "detalleIA");

    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Información de la observación</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Fecha</div><div class="fw-semibold">@Str(o.Value, "fechaObservacion")</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Objeto celeste</div><div>@Str(o.Value, "objetoCeleste")</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Tipo de objeto</div><div>@Str(o.Value, "tipoObjeto")</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Telescopio</div><div>@Str(o.Value, "telescopio")</div></div>
                <div class="col-sm-6 col-md-4"><div class="text-muted small">Socio</div><div>@Str(o.Value, "socio")</div></div>
            </div>
            @{ var notas = Str(o.Value, "notas"); }
            @if (notas != "—" && !string.IsNullOrWhiteSpace(notas))
            {
                <div class="mt-3"><div class="text-muted small">Notas</div><div>@notas</div></div>
            }
        </div>
    </div>

    @if (indicador != "—" && !string.IsNullOrWhiteSpace(indicador))
    {
        <div class="alert alert-@css">
            <strong>Evaluación IA: @indicador</strong>
            @if (detalle != "—" && !string.IsNullOrWhiteSpace(detalle)) { <p class="mb-0 mt-1">@detalle</p> }
        </div>
    }
}
