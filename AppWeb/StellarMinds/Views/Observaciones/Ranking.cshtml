@model List<StellarMinds.Models.Observaciones.RankingItem>
@{
    ViewData["Title"] = "Ranking de objetos celestes";
}
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Ranking de objetos celestes observados</h2></div>
@if (!Model.Any()) { <div class="alert alert-info">Aún no hay observaciones registradas.</div> }
else
{
    <div class="card shadow-sm"><div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark"><tr><th style="width:80px">#</th><th>Objeto celeste</th><th>Tipo</th><th class="text-center">Observaciones</th></tr></thead>
            <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>
                        @if (item.Posicion == 1) { <span class="badge bg-warning text-dark">1</span> }
                        else if (item.Posicion == 2) { <span class="badge bg-secondary">2</span> }
                        else if (item.Posicion == 3) { <span class="badge" style="background-color:#cd7f32">3</span> }
                        else { <span class="text-muted">@item.Posicion</span> }
                    </td>
                    <td class="fw-semibold">@item.Nombre</td>
                    <td><span class="badge bg-info text-dark">@item.Tipo</span></td>
                    <td class="text-center fw-bold">@item.CantidadObservaciones</td>
                </tr>
            }
            </tbody>
        </table>
    </div></div>
}
