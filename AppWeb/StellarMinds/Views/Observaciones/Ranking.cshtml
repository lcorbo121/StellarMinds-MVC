@{
    ViewData["Title"] = "Ranking de objetos celestes";
    var ranking = ViewBag.Ranking as List<System.Text.Json.JsonElement> ?? [];
}
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Ranking de objetos celestes observados</h2></div>
@if (!ranking.Any()) { <div class="alert alert-info">Aún no hay observaciones registradas.</div> }
else
{
    <div class="card shadow-sm"><div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark"><tr><th style="width:80px">#</th><th>Objeto celeste</th><th>Tipo</th><th class="text-center">Observaciones</th></tr></thead>
            <tbody>
            @foreach (var item in ranking) {
                var pos = item.TryGetProperty("posicion", out var pp) ? pp.GetInt32() : 0;
                var nombre = item.TryGetProperty("nombre", out var np) ? np.GetString() : "-";
                var tipo = item.TryGetProperty("tipo", out var tp) ? tp.GetString() : "-";
                var cant = item.TryGetProperty("cantidadObservaciones", out var cp) ? cp.GetInt32() : 0;
                <tr>
                    <td>
                        @if (pos == 1) { <span class="badge bg-warning text-dark">1</span> }
                        else if (pos == 2) { <span class="badge bg-secondary">2</span> }
                        else if (pos == 3) { <span class="badge" style="background-color:#cd7f32">3</span> }
                        else { <span class="text-muted">@pos</span> }
                    </td>
                    <td class="fw-semibold">@nombre</td>
                    <td><span class="badge bg-info text-dark">@tipo</span></td>
                    <td class="text-center fw-bold">@cant</td>
                </tr>
            }
            </tbody>
        </table>
    </div></div>
}
