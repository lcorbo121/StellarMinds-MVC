@model List<StellarMinds.Models.Observaciones.ObservacionItem>
@{
    ViewData["Title"] = "Mis observaciones";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Mis observaciones</h2>
    <a asp-action="Create" class="btn btn-success btn-sm">+ Nueva observación</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No tenés observaciones registradas aún.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Fecha</th>
                    <th>Objeto celeste</th>
                    <th>Tipo</th>
                    <th>Telescopio</th>
                    <th>Evaluación IA</th>
                    <th>Notas</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obs in Model)
                {
                    var badgeCss = obs.IndicadorIA switch { "IDEAL" => "success", "ADECUADO" => "warning", "NO RECOMENDABLE" => "danger", _ => "secondary" };
                    <tr>
                        <td class="text-muted small">@obs.Id</td>
                        <td>@obs.FechaObservacion</td>
                        <td><strong>@obs.ObjetoCeleste</strong></td>
                        <td><span class="badge bg-secondary">@obs.TipoObjeto</span></td>
                        <td>@obs.Telescopio</td>
                        <td>
                            @if (!string.IsNullOrEmpty(obs.IndicadorIA))
                            {
                                <span class="badge bg-@badgeCss">@obs.IndicadorIA</span>
                                @if (!string.IsNullOrEmpty(obs.DetalleIA))
                                {
                                    <button type="button" class="btn btn-link btn-sm p-0 ms-1"
                                            data-bs-toggle="popover" data-bs-trigger="focus"
                                            data-bs-content="@obs.DetalleIA" title="Detalle IA">
                                        <small>ver detalle</small>
                                    </button>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(obs.Notas))
                            {
                                <span class="text-truncate d-inline-block" style="max-width:200px" title="@obs.Notas">@obs.Notas</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function(el) {
        new bootstrap.Popover(el, { html: false });
    });
</script>
}
